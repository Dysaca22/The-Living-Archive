# VITE_TMDB_API_KEY: Required for movie metadata and artwork resolution.
# Get your free key from https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY="MY_TMDB_API_KEY"

# GEMINI_API_KEY: (Optional) Can be set here or provided via the UI.
# AI Studio automatically injects this at runtime from user secrets if configured.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# REMOTE_VAULT_URL: (Optional) URL of a Google Apps Script or remote API
# for cloud persistence. If not set, the app defaults to local-only mode.
REMOTE_VAULT_URL="https://script.google.com/macros/s/.../exec"
