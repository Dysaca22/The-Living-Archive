# TMDB_READ_ACCESS_TOKEN: Required for movie metadata and artwork resolution.
# Get your API Read Access Token from https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN="MY_TMDB_READ_ACCESS_TOKEN"

# GEMINI_API_KEY: (Optional) Can be set here or provided via the UI.
# AI Studio automatically injects this at runtime from user secrets if configured.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
